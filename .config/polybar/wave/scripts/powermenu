#!/usr/bin/env bash

rofi_command="rofi -theme ~/.config/polybar/wave/scripts/rofi/powermenu.rasi"

uptime=$(uptime -p | sed -e 's/up //g')

# Options
if [[ "$DIR" == "powermenus" ]]; then
	shutdown="ÓßÄ"
	reboot="ÓßÑ"
	lock="Ó¶è"
	suspend="Ó¶£"
	logout="Ó¶ë"
	ddir="$HOME/.config/rofi/$DIR"
else
	shutdown="ÓßÄ Shutdown"
	reboot="ÓßÑ Restart"
	lock="Ó¶è Lock"
	suspend="Ó¶£ Sleep"
	logout="Ó¶ë Logout"
	ddir="$HOME/.config/rofi/dialogs"
fi

rdialog () {
rofi -dmenu\
    -i\
    -no-fixed-num-lines\
    -p "Are You Sure? : "\
    -theme "$ddir/confirm.rasi"
}

# Variable passed to rofi
MSG="Options : yes / no / y / n"
options="$lock\n$suspend\n$logout\n$reboot\n$shutdown"

chosen="$(echo -e "$options" | $rofi_command -p "UP - $uptime" -dmenu -selected-row 0)"
case $chosen in
    $shutdown)
		ans=$(rdialog &)
		if [[ $ans == "yes" ]] || [[ $ans == "YES" ]] || [[ $ans == "y" ]]; then
        systemctl poweroff
		elif [[ $ans == "no" ]] || [[ $ans == "NO" ]] || [[ $ans == "n" ]]; then
        exit
        else
        rofi -theme "$ddir/askpass.rasi" -e "$MSG"
        fi
        ;;
    $reboot)
		ans=$(rdialog &)
		if [[ $ans == "yes" ]] || [[ $ans == "YES" ]] || [[ $ans == "y" ]]; then
        systemctl reboot
		elif [[ $ans == "no" ]] || [[ $ans == "NO" ]] || [[ $ans == "n" ]]; then
        exit
        else
        rofi -theme "$ddir/askpass.rasi" -e "$MSG"
        fi
        ;;
    $lock)
        betterlockscreen --lock
        ;;
    $suspend)
		ans=$(rdialog &)
		if [[ $ans == "yes" ]] || [[ $ans == "YES" ]] || [[ $ans == "y" ]]; then
        mpc -q pause
        amixer set Master mute
        betterlockscreen --suspend
		elif [[ $ans == "no" ]] || [[ $ans == "NO" ]] || [[ $ans == "n" ]]; then
        exit
        else
        rofi -theme "$ddir/askpass.rasi" -e "$MSG"
        fi
        ;;
    $logout)
		ans=$(rdialog &)
		if [[ $ans == "yes" ]] || [[ $ans == "YES" ]] || [[ $ans == "y" ]]; then
        openbox --exit
		elif [[ $ans == "no" ]] || [[ $ans == "NO" ]] || [[ $ans == "n" ]]; then
        exit
        else
        rofi -theme "$ddir/askpass.rasi" -e "$MSG"
        fi
        ;;
esac

